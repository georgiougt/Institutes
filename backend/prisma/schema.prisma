generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ──────────────────────────────────────────────────────────────────

enum Role {
  USER
  OWNER
  ADMIN
}

enum AdminRole {
  SUPER_ADMIN
  OPS_ADMIN
  SUPPORT_ADMIN
  CONTENT_MOD
}

enum ListingStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
  ARCHIVED
}

enum ClaimStatus {
  SUBMITTED
  UNDER_REVIEW
  NEEDS_MORE_INFO
  APPROVED
  REJECTED
  CANCELED
}

enum ContactStatus {
  NEW
  READ
  ASSIGNED
  RESOLVED
  SPAM
  ARCHIVED
}

enum InstRole {
  OWNER
  MANAGER
  STAFF
}

enum RevStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── USER ───────────────────────────────────────────────────────────────────

model User {
  id              String            @id @default(uuid())
  email           String            @unique
  passwordHash    String?
  firstName       String?
  lastName        String?
  phone           String?
  role            Role              @default(USER)
  adminRole       AdminRole?
  isSuspended     Boolean           @default(false)
  suspendedAt     DateTime?
  suspendReason   String?
  lastLoginAt     DateTime?
  emailVerifiedAt DateTime?
  onboardingStep  Int?              @default(1)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  ownedInstitutes   Institute[]       @relation("OwnerInstitutes")
  memberships       InstituteMember[]
  favorites         Favorite[]
  contactRequests   ContactRequest[]
  auditLogs         AuditLog[]        @relation("AuditActor")
  claimsSubmitted   Claim[]
  reviewAssignments ReviewAssignment[]
}

// ─── INSTITUTE ──────────────────────────────────────────────────────────────

model Institute {
  id              String            @id @default(uuid())
  ownerId         String
  name            String
  slug            String?           @unique
  description     String?
  status          ListingStatus     @default(DRAFT)
  isFlagged       Boolean           @default(false)
  flagReason      String?
  logoUrl         String?
  website         String?
  mergedIntoId    String?
  viewCount       Int               @default(0)
  completenessScore Int             @default(0)
  isClaimed       Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?

  owner             User                     @relation("OwnerInstitutes", fields: [ownerId], references: [id])
  members           InstituteMember[]
  revisions         InstituteRevision[]
  mergedInto        Institute?               @relation("MergedInstitutes", fields: [mergedIntoId], references: [id])
  mergedFrom        Institute[]              @relation("MergedInstitutes")
  branches          Branch[]
  services          InstituteService[]
  images            Image[]
  contactRequests   ContactRequest[]
  claims            Claim[]
  featuredListings  FeaturedListing[]
  moderationNotes   ModerationNote[]
  statusHistory     InstituteStatusHistory[]

  @@index([status])
  @@index([ownerId])
  @@index([createdAt])
}

model InstituteStatusHistory {
  id            String        @id @default(uuid())
  instituteId   String
  fromStatus    ListingStatus
  toStatus      ListingStatus
  reason        String?
  changedBy     String
  createdAt     DateTime      @default(now())

  institute     Institute     @relation(fields: [instituteId], references: [id], onDelete: Cascade)
}

model ModerationNote {
  id            String    @id @default(uuid())
  instituteId   String
  authorId      String
  content       String
  isInternal    Boolean   @default(true)
  createdAt     DateTime  @default(now())

  institute     Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)
}

// ─── BRANCH ─────────────────────────────────────────────────────────────────

model Branch {
  id              String            @id @default(uuid())
  instituteId     String
  name            String
  email           String?
  phone           String
  address         String
  cityId          String
  areaId          String?

  latitude        Float
  longitude       Float

  isMain          Boolean           @default(false)
  status          ListingStatus     @default(PENDING)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?

  institute       Institute         @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  city            City              @relation(fields: [cityId], references: [id])
  area            Area?             @relation(fields: [areaId], references: [id])
  schedules       Schedule[]
  favorites       Favorite[]

  @@index([latitude, longitude])
}

// ─── SERVICE / TAXONOMY ─────────────────────────────────────────────────────

model Service {
  id              String            @id @default(uuid())
  name            String            @unique
  slug            String?           @unique
  category        String?
  description     String?
  iconUrl         String?
  displayOrder    Int               @default(0)
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  institutes      InstituteService[]

  @@index([displayOrder])
}

model InstituteService {
  id              String            @id @default(uuid())
  instituteId     String
  serviceId       String
  priceInfo       String?
  isOnline        Boolean           @default(false)
  isInPerson      Boolean           @default(true)

  institute       Institute         @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  service         Service           @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([instituteId, serviceId])
}

// ─── SCHEDULE ───────────────────────────────────────────────────────────────

model Schedule {
  id              String            @id @default(uuid())
  branchId        String
  dayOfWeek       Int
  openTime        String
  closeTime       String
  isClosed        Boolean           @default(false)

  branch          Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, dayOfWeek])
}

// ─── CONTACT REQUESTS ───────────────────────────────────────────────────────

model ContactRequest {
  id              String            @id @default(uuid())
  instituteId     String
  userId          String?
  guestName       String?
  guestEmail      String?
  guestPhone      String?
  serviceId       String?
  message         String
  status          ContactStatus     @default(NEW)
  isSpam          Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  institute       Institute         @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  user            User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  notes           InquiryNote[]

  @@index([status])
  @@index([instituteId])
  @@index([createdAt])
}

// ─── FAVORITES ──────────────────────────────────────────────────────────────

model Favorite {
  id              String            @id @default(uuid())
  userId          String
  branchId        String
  createdAt       DateTime          @default(now())

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch          Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
}

// ─── LOCATIONS ──────────────────────────────────────────────────────────────

model City {
  id              String            @id @default(uuid())
  name            String            @unique
  nameEn          String?
  slug            String?           @unique
  displayOrder    Int               @default(0)
  createdAt       DateTime          @default(now())

  branches        Branch[]
  areas           Area[]
}

model Area {
  id              String            @id @default(uuid())
  cityId          String
  name            String
  nameEn          String?
  slug            String?

  city            City              @relation(fields: [cityId], references: [id], onDelete: Cascade)
  branches        Branch[]

  @@unique([cityId, name])
}

// ─── IMAGES ─────────────────────────────────────────────────────────────────

model Image {
  id              String            @id @default(uuid())
  instituteId     String
  url             String
  caption         String?
  order           Int               @default(0)
  isApproved      Boolean           @default(false)
  createdAt       DateTime          @default(now())

  institute       Institute         @relation(fields: [instituteId], references: [id], onDelete: Cascade)
}

// ─── CLAIMS ─────────────────────────────────────────────────────────────────

model Claim {
  id              String            @id @default(uuid())
  instituteId     String
  claimantId      String
  claimerEmail    String
  claimerPhone    String?
  message         String?
  status          ClaimStatus       @default(SUBMITTED)
  proofUrl        String?
  reviewerId      String?
  reviewNotes     String?
  resolvedAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  institute       Institute         @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  claimant        User              @relation(fields: [claimantId], references: [id])

  @@index([status])
}

// ─── FEATURED LISTINGS ──────────────────────────────────────────────────────

model FeaturedListing {
  id              String            @id @default(uuid())
  instituteId     String
  placementType   String            // 'homepage' | 'category' | 'city'
  placementKey    String?
  priority        Int               @default(0)
  startsAt        DateTime
  endsAt          DateTime?
  isActive        Boolean           @default(true)
  createdBy       String
  createdAt       DateTime          @default(now())

  institute       Institute         @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  @@index([placementType, isActive])
}

// ─── REVIEW ASSIGNMENTS ─────────────────────────────────────────────────────

model ReviewAssignment {
  id              String            @id @default(uuid())
  adminId         String
  entityType      String
  entityId        String
  assignedAt      DateTime          @default(now())
  completedAt     DateTime?

  admin           User              @relation(fields: [adminId], references: [id])
}

// ──── MEMBERSHIP & ROLES ────────────────────────────────────────

model InstituteMember {
  id          String   @id @default(uuid())
  instituteId String
  userId      String
  role        InstRole @default(STAFF)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([instituteId, userId])
}

// ──── VERSIONING & REVISIONS ────────────────────────────────────

model InstituteRevision {
  id          String    @id @default(uuid())
  instituteId String
  proposedData Json      // Full snapshot of modified fields
  currentData  Json?     // Snapshot at time of revision for comparison
  status      RevStatus @default(PENDING)
  adminNote   String?
  appliedAt   DateTime?
  appliedBy   String?   // Admin user ID
  createdAt   DateTime  @default(now())
  
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)
}

// ──── CRM & INQUIRIES ─────────────────────────────────────────

model InquiryNote {
  id               String   @id @default(uuid())
  contactRequestId String
  authorId         String
  content          String
  createdAt        DateTime @default(now())
  
  contactRequest   ContactRequest @relation(fields: [contactRequestId], references: [id], onDelete: Cascade)
}

// ─── AUDIT LOGS ─────────────────────────────────────────────────────────────

model AuditLog {
  id              String            @id @default(uuid())
  actorId         String?
  actorRole       String?
  actionType      String
  entityType      String?
  entityId        String?
  oldValues       Json?
  newValues       Json?
  reason          String?
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime          @default(now())

  actor           User?             @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actionType])
  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
}

// ─── PLATFORM SETTINGS ──────────────────────────────────────────────────────

model PlatformSetting {
  id              String            @id @default(uuid())
  key             String            @unique
  value           Json
  updatedBy       String?
  updatedAt       DateTime          @updatedAt
}
